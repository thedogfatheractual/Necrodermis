#!/usr/bin/env bash
# ============================================================
#  necro-bump — manual version bump for minor/major releases
#  Usage:
#    necro-bump minor    →  1.3.x → 1.4.0
#    necro-bump major    →  1.x.x → 2.0.0
#    necro-bump patch    →  1.3.x → 1.3.x+1  (hook does this automatically)
# ============================================================

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [[ -z "$REPO_ROOT" ]]; then
  echo "[necro-bump] ERROR: not inside a git repo"
  exit 1
fi

VERSION_FILE="$REPO_ROOT/VERSION"
if [[ ! -f "$VERSION_FILE" ]]; then
  echo "[necro-bump] ERROR: VERSION file not found"
  exit 1
fi

BUMP="${1:-patch}"
CURRENT="$(cat "$VERSION_FILE" | tr -d '[:space:]')"
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)

case "$BUMP" in
  major)
    NEW_VERSION="$((MAJOR + 1)).0.0"
    ;;
  minor)
    NEW_VERSION="${MAJOR}.$((MINOR + 1)).0"
    ;;
  patch)
    NEW_VERSION="${MAJOR}.${MINOR}.$((PATCH + 1))"
    ;;
  *)
    echo "[necro-bump] Usage: necro-bump [major|minor|patch]"
    exit 1
    ;;
esac

echo "$NEW_VERSION" > "$VERSION_FILE"
git add "$VERSION_FILE"
git commit --no-verify -m "chore: bump version ${CURRENT} → ${NEW_VERSION} 🪦" --quiet

echo "[necro-bump] Version bumped: ${CURRENT} → ${NEW_VERSION}"
echo "[necro-bump] Now run: git push"
